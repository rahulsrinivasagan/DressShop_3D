/* -------------------------------------------------------------------------- */
/*  1. HERO â€” layered parallax + mouse parallax + scroll zoom                 */
/* -------------------------------------------------------------------------- */
function CinematicHero() {
  const root = useRef<HTMLElement>(null);

  useLayoutEffect(() => {
    const ctx = gsap.context(() => {
      // Scroll-driven camera zoom + depth
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: root.current,
          start: "top top",
          end: "bottom top",
          scrub: 1.2,
        },
      });
      tl.to(".hero-bg", { scale: 1.35, yPercent: 12, ease: "none" }, 0)
        .to(".hero-mid", { scale: 1.15, yPercent: 22, ease: "none" }, 0)
        .to(".hero-fg", { yPercent: 38, ease: "none" }, 0)
        .to(".hero-headline", { yPercent: -90, letterSpacing: "0.1em", ease: "power2.in" }, 0)
        .to(".hero-sub", { yPercent: -200, opacity: 0, ease: "power3.in" }, 0)
        .to(".hero-vignette", { opacity: 1, ease: "none" }, 0);

      // Cinematic intro
      gsap.from(".hero-headline .word", {
        yPercent: 110,
        rotateX: -40,
        duration: 1.6,
        stagger: 0.12,
        ease: "expo.out",
        delay: 0.3,
      });
      gsap.from(".hero-meta", { opacity: 0, y: 30, duration: 1.4, delay: 1.2, ease: "expo.out" });
    }, root);

    // Mouse parallax
    const onMove = (e: MouseEvent) => {
      const x = (e.clientX / window.innerWidth - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      gsap.to(".hero-bg", { x: x * -20, y: y * -10, duration: 1.2, ease: "power3.out" });
      gsap.to(".hero-mid", { x: x * -40, y: y * -20, duration: 1.2, ease: "power3.out" });
      gsap.to(".hero-fg", { x: x * -70, y: y * -35, duration: 1.2, ease: "power3.out" });
      gsap.to(".hero-headline", { x: x * 15, y: y * 8, duration: 1.4, ease: "power3.out" });
    };
    window.addEventListener("mousemove", onMove);
    return () => {
      window.removeEventListener("mousemove", onMove);
      ctx.revert();
    };
  }, []);

  // removed (moved to lazy-loaded component)
    <section ref={root} className="relative h-[120vh] w-full overflow-hidden">
      <div className="sticky top-0 h-screen w-full overflow-hidden">
        {/* Background â€” slowest, deepest */}
        <div className="hero-bg absolute inset-0 z-0 will-change-transform">
          <img src={hero} alt="Cinematic fashion editorial" className="w-full h-full object-cover scale-110 opacity-70" />
          <div className="absolute inset-0 bg-gradient-to-b from-background/30 via-transparent to-background" />
        </div>

        {/* Midground â€” abstract light/shadow strokes */}
        <div className="hero-mid absolute inset-0 z-10 pointer-events-none will-change-transform">
          <div className="absolute top-[20%] -left-20 w-[60vw] h-[60vh] rounded-full blur-3xl bg-accent/10" />
          <div className="absolute bottom-[10%] -right-32 w-[50vw] h-[50vh] rounded-full blur-3xl bg-foreground/5" />
        </div>

        {/* Foreground â€” typography */}
        <div className="hero-fg absolute inset-0 z-20 flex items-center justify-center px-6 will-change-transform">
          <div className="text-center">
            <h1 className="hero-headline overflow-hidden text-[clamp(4rem,16vw,16rem)] font-display italic leading-[0.82] tracking-tighter">
              <span className="word inline-block">The&nbsp;</span>
              <span className="word inline-block">Weight</span>
              <br />
              <span className="word inline-block not-italic font-sans font-extrabold text-foreground">OF</span>{" "}
              <span className="word inline-block not-italic font-sans font-extrabold text-foreground">LIGHT</span>
            </h1>
          </div>
        </div>

        {/* Meta corners */}
        <div className="hero-meta absolute top-28 left-6 md:left-12 z-30 font-mono text-[10px] uppercase tracking-[0.4em] opacity-70">
          A Cinematic
          <br />Study / 04 â€” 24
        </div>
        <div className="hero-meta absolute top-28 right-6 md:right-12 z-30 font-mono text-[10px] uppercase tracking-[0.4em] text-right opacity-70">
          Atelier Chennai
          <br />48Â°51â€² N
        </div>

        <div className="hero-sub absolute bottom-16 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-4">
          <span className="text-[9px] font-mono uppercase tracking-[0.5em] opacity-60">Scroll to enter</span>
          <div className="w-px h-20 bg-gradient-to-b from-transparent via-foreground/60 to-transparent" />
        </div>

        {/* Cinematic vignette darkens as you scroll into next scene */}
        <div className="hero-vignette absolute inset-0 z-40 pointer-events-none opacity-0 bg-[radial-gradient(ellipse_at_center,transparent_30%,black_100%)]" />
      </div>
    </section>
  );
}

/* -------------------------------------------------------------------------- */
/*  2. SCROLL STORY â€” pinned dolly-forward scene                              */
/* -------------------------------------------------------------------------- */
function ScrollStory() {
  const root = useRef<HTMLElement>(null);

  useLayoutEffect(() => {
    const ctx = gsap.context(() => {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: root.current,
          start: "top top",
          end: "+=300%",
          scrub: 1.5,
          pin: true,
          anticipatePin: 1,
        },
      });

      // Camera dolly forward â€” image grows past the viewport
      tl.fromTo(
        ".story-img",
        { scale: 0.6, filter: "blur(8px) brightness(0.45)" },
        { scale: 1.35, filter: "blur(0px) brightness(1)", ease: "power2.inOut", duration: 2 },
        0,
      );
      tl.to(".story-img", { scale: 2.4, filter: "blur(20px) brightness(0.4)", ease: "power3.in", duration: 1.2 }, 2);

      // Text rises from depth â€” staggered
      tl.fromTo(".story-line", { yPercent: 130, opacity: 0 }, { yPercent: 0, opacity: 1, stagger: 0.25, ease: "expo.out", duration: 1.4 }, 0.3);
      tl.to(".story-line", { yPercent: -130, opacity: 0, stagger: 0.15, ease: "power3.in", duration: 1 }, 2);

      // Floating frame elements drift past camera
      tl.fromTo(
        ".float-frame",
        { yPercent: (i) => 60 + i * 20, xPercent: (i) => (i % 2 === 0 ? -40 : 40), opacity: 0, rotate: (i) => (i % 2 === 0 ? -6 : 6) },
        { yPercent: -120, opacity: 1, ease: "none", stagger: 0.2, duration: 3.2 },
        0,
      );

      // Chromatic / scale on caption
      tl.fromTo(".story-caption", { opacity: 0, letterSpacing: "0.2em" }, { opacity: 1, letterSpacing: "0.5em", ease: "power2.out", duration: 1.5 }, 1.2);
    }, root);
    return () => ctx.revert();
  }, []);

  return (
    <section ref={root} className="relative h-screen w-full overflow-hidden bg-background">
      {/* Camera target image */}
      <div className="absolute inset-0 flex items-center justify-center">
        <div className="story-img relative w-[55vw] h-[80vh] overflow-hidden will-change-transform">
          <img src={fabric} alt="Silk in cinematic light" className="w-full h-full object-cover" />
          <div className="absolute inset-0 ring-1 ring-white/10" />
        </div>
      </div>

      {/* Floating frames drift up (depth parallax) */}
      {[look1, studio, look2, fabric, look3].map((src, i) => (
        <div
          key={i}
          className="float-frame absolute will-change-transform"
          style={{
            left: `${10 + (i * 17) % 70}%`,
            top: `${15 + (i * 23) % 60}%`,
            width: `${120 + (i % 3) * 60}px`,
            height: `${160 + (i % 3) * 80}px`,
            opacity: 0,
            zIndex: i % 2 === 0 ? 5 : 25,
            filter: `blur(${i % 2 === 0 ? 4 : 0}px)`,
          }}
        >
          <img src={src} alt="" className="w-full h-full object-cover ring-1 ring-white/10" />
        </div>
      ))}

      {/* Overlay copy */}
      <div className="absolute inset-0 z-30 flex flex-col items-center justify-center text-center px-6 pointer-events-none">
        <div className="overflow-hidden">
          <p className="story-line text-xs md:text-sm font-mono uppercase tracking-[0.5em] text-accent">02 â€” Materiality</p>
        </div>
        <div className="overflow-hidden mt-6">
          <h2 className="story-line text-5xl md:text-8xl font-display italic leading-[0.9] text-balance max-w-4xl">
            Silk that breathes
          </h2>
        </div>
        <div className="overflow-hidden">
          <h2 className="story-line text-5xl md:text-8xl font-display italic leading-[0.9] text-balance max-w-4xl">
            like stone.
          </h2>
        </div>
        <div className="overflow-hidden mt-8 max-w-md">
          <p className="story-line text-sm text-muted-foreground leading-relaxed">
            Forty hours by hand. The fabric finds its own resting line.
          </p>
        </div>
      </div>

      <div className="story-caption absolute bottom-12 left-1/2 -translate-x-1/2 z-40 font-mono text-[9px] uppercase text-foreground/40">
        Camera 01 / Dolly in
      </div>
    </section>
  );
}

/* -------------------------------------------------------------------------- */
/*  3. HORIZONTAL GALLERY â€” vertical scroll â†’ horizontal travel               */
/* -------------------------------------------------------------------------- */
function HorizontalGallery() {
  const root = useRef<HTMLElement>(null);
  const track = useRef<HTMLDivElement>(null);
  const toggleWishlist = useWishlistStore((s) => s.toggleWishlist);
  const isWishlisted = useWishlistStore((s) => s.isWishlisted);

  useLayoutEffect(() => {
    const ctx = gsap.context(() => {
      const trackEl = track.current!;
      const distance = () => trackEl.scrollWidth - window.innerWidth;

      gsap.to(trackEl, {
        x: () => -distance(),
        ease: "none",
        scrollTrigger: {
          trigger: root.current,
          start: "top top",
          end: () => `+=${distance()}`,
          scrub: 1,
          pin: true,
          invalidateOnRefresh: true,
        },
      });

      // Per-card cinematic scale based on horizontal position
      gsap.utils.toArray<HTMLElement>(".h-card").forEach((card) => {
        gsap.fromTo(
          card.querySelector("img"),
          { scale: 1.4, filter: "blur(6px) brightness(0.6)" },
          {
            scale: 1,
            filter: "blur(0px) brightness(1)",
            ease: "none",
            scrollTrigger: {
              trigger: card,
              containerAnimation: ScrollTrigger.getAll().find((s) => s.trigger === root.current)?.animation,
              start: "left right",
              end: "right left",
              scrub: true,
            },
          },
        );
      });
    }, root);
    return () => ctx.revert();
  }, []);

  return (
    <section ref={root} className="relative h-screen w-full overflow-hidden bg-foreground text-background">
      <div className="absolute top-12 left-6 md:left-12 z-30 flex items-end justify-between w-[calc(100%-3rem)] md:w-[calc(100%-6rem)]">
        <div>
          <p className="font-mono text-[10px] uppercase tracking-[0.4em] opacity-50">03 â€” Collection</p>
          <h3 className="text-5xl md:text-8xl font-display italic mt-3 tracking-tighter">The Archive</h3>
        </div>
        <span className="hidden md:block font-mono text-[10px] uppercase tracking-widest opacity-60">
          Scroll horizontally â†’
        </span>
      </div>

      <div ref={track} className="absolute top-1/2 -translate-y-1/2 flex gap-8 pl-[8vw] pr-[40vw] will-change-transform">
        {products.map((p, i) => (
          <Link
            key={p.id}
            to="/product/$id"
            params={{ id: p.id }}
            className={`h-card flex-none w-[70vw] md:w-[34vw] block group ${i % 2 === 1 ? "md:translate-y-16" : "md:-translate-y-10"}`}
          >
            <div className="aspect-[3/4] overflow-hidden bg-stone-200 ring-1 ring-black/10 relative">
              <img src={p.image} alt={p.name} className="w-full h-full object-cover will-change-transform" loading="lazy" />
              <button
                aria-label="Toggle wishlist"
                onClick={(e) => {
                  e.preventDefault();
                  e.stopPropagation();
                  toggleWishlist({ id: p.id, name: p.name, price: p.price, image: p.image });
                }}
                className="absolute top-4 right-4 w-10 h-10 rounded-full border border-black/10 bg-white/60 backdrop-blur flex items-center justify-center hover:bg-white/80 transition-colors"
              >
                <Heart className="h-4 w-4" fill={isWishlisted(p.id) ? "currentColor" : "none"} />
              </button>
            </div>
            <div className="pt-5 flex justify-between items-end">
              <div>
                <p className="text-xs uppercase tracking-tight font-medium">{p.name}</p>
                <p className="font-mono text-[10px] uppercase opacity-60 mt-1">{p.category}</p>
              </div>
              <span className="font-mono text-[10px]">{formatINR(p.price)}</span>
            </div>
          </Link>
        ))}
      </div>
    </section>
  );
}

