function SilkObject({ progressRef }: { progressRef: React.MutableRefObject<{ v: number }> }) {
  const mesh = useRef<THREE.Mesh>(null);
  useFrame((state) => {
    const p = progressRef.current.v;
    if (!mesh.current) return;
    mesh.current.rotation.y = p * Math.PI * 2 + state.clock.elapsedTime * 0.15;
    mesh.current.rotation.x = Math.sin(p * Math.PI) * 0.4;
    const s = 1 + Math.sin(p * Math.PI) * 0.35;
    mesh.current.scale.setScalar(s);
    // Camera dolly
    state.camera.position.z = 5 - p * 1.6;
    state.camera.position.y = Math.sin(p * Math.PI * 0.5) * 0.5;
    state.camera.lookAt(0, 0, 0);
  });
  return (
    <Float speed={1.4} rotationIntensity={0.3} floatIntensity={0.6}>
      <mesh ref={mesh}>
        <torusKnotGeometry args={[0.95, 0.32, 220, 32]} />
        <MeshDistortMaterial
          color="#d8c9a8"
          roughness={0.25}
          metalness={0.35}
          distort={0.45}
          speed={1.2}
        />
      </mesh>
    </Float>
  );
}

/* -------------------------------------------------------------------------- */
/*  5. FINAL CTA â€” zoom-out reveal                                            */
/* -------------------------------------------------------------------------- */
function FinalCTA() {
  const root = useRef<HTMLElement>(null);

  useLayoutEffect(() => {
    const ctx = gsap.context(() => {
      gsap.fromTo(
        ".cta-img",
        { scale: 2, filter: "blur(20px) brightness(0.3)" },
        {
          scale: 1,
          filter: "blur(0px) brightness(0.7)",
          ease: "power3.out",
          scrollTrigger: {
            trigger: root.current,
            start: "top bottom",
            end: "center center",
            scrub: 1.4,
          },
        },
      );
      gsap.fromTo(
        ".cta-content > *",
        { y: 60, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          stagger: 0.15,
          ease: "expo.out",
          scrollTrigger: {
            trigger: root.current,
            start: "top 60%",
            end: "center center",
            scrub: 1,
          },
        },
      );
    }, root);
    return () => ctx.revert();
  }, []);

  return (
    <section ref={root} className="relative h-screen w-full overflow-hidden flex items-center justify-center">
      <div className="cta-img absolute inset-0 z-0 will-change-transform">
        <img src={studio} alt="Studio shadow play" className="w-full h-full object-cover" />
        <div className="absolute inset-0 bg-gradient-to-b from-background/50 via-background/30 to-background" />
      </div>
      <div className="cta-content relative z-10 text-center px-6 max-w-3xl">
        <p className="font-mono text-[10px] uppercase tracking-[0.5em] text-accent">05 â€” Atelier</p>
        <h2 className="mt-6 text-5xl md:text-8xl font-display italic leading-[0.9]">
          Step into the frame.
        </h2>
        <p className="mt-8 text-sm text-muted-foreground max-w-md mx-auto leading-relaxed">
          Private studio viewings by appointment. Each garment hand-finished in Chennai.
        </p>
        <div className="mt-12 flex flex-col md:flex-row gap-4 justify-center">
          <Link to="/shop" className="px-12 py-5 bg-foreground text-background rounded-full text-[10px] font-mono uppercase tracking-[0.4em] hover:bg-accent transition-colors duration-700">
            Enter the Archive
          </Link>
          <Link to="/contact" className="px-12 py-5 border border-foreground/30 rounded-full text-[10px] font-mono uppercase tracking-[0.4em] hover:bg-foreground hover:text-background transition-all duration-700">
            Request Viewing
          </Link>
        </div>
      </div>
    </section>
  );
}
